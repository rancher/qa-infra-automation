---
# K3s Deployment Variables Template
# Copy this file to vars.yaml and customize for your environment:
# cp vars.yaml.example vars.yaml

# K3s version and installation settings
kubernetes_version: 'v1.32.1+k3s1'
kubeconfig_file: './kubeconfig.yaml'

# CIS hardening (opt-in).
# Set to true to apply CIS benchmark hardening before installation.
# Alternatively, including 'protect-kernel-defaults: true' in server_flags
# also enables hardening as a fallback (legacy behaviour).
harden: false

# Optional server/worker flags for custom k3s args.
# Note: setting 'protect-kernel-defaults: true' here also enables CIS hardening.
server_flags: ""

worker_flags: ""

# Optional channel for K3s installation
channel: "stable"

# Node token file for cluster communication
node_token_file: "/tmp/node_token.txt"
