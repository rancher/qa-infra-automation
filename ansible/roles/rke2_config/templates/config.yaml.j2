# RKE2 configuration file
# Generated by Ansible - rke2_config role
# Node: {{ inventory_hostname }}
# Role: {{ rke2_node_role }}

{% if rke2_node_role == 'master' or 'cp' in node_roles.split(',') or 'etcd' in node_roles.split(',') %}
# Server node configuration
{% for key, value in rke2_server_config.items() %}
{% if value is string %}
{{ key }}: {{ value }}
{% elif value is sequence and value is not string %}
{{ key }}:
{% for item in value %}
  - {{ item }}
{% endfor %}
{% elif value is mapping %}
{{ key }}:
{% for subkey, subvalue in value.items() %}
  {{ subkey }}: {{ subvalue }}
{% endfor %}
{% else %}
{{ key }}: {{ value }}
{% endif %}
{% endfor %}

{% if rke2_node_role != 'master' %}
# Join to existing cluster
server: https://{{ kube_api_host }}:9345
{% endif %}

{% if rke2_token is defined and rke2_token != '' %}
token: {{ rke2_token }}
{% endif %}

{% else %}
# Agent node configuration
{% for key, value in rke2_agent_config.items() %}
{% if value is string %}
{{ key }}: {{ value }}
{% elif value is sequence and value is not string %}
{{ key }}:
{% for item in value %}
  - {{ item }}
{% endfor %}
{% else %}
{{ key }}: {{ value }}
{% endif %}
{% endfor %}

{% if rke2_token is defined and rke2_token != '' %}
token: {{ rke2_token }}
{% endif %}
{% endif %}

{% if rke2_disable_components | length > 0 %}
# Disabled components
disable:
{% for component in rke2_disable_components %}
  - {{ component }}
{% endfor %}
{% endif %}

{% if rke2_additional_config | length > 0 %}
# Additional configuration
{% for key, value in rke2_additional_config.items() %}
{% if value is string %}
{{ key }}: {{ value }}
{% elif value is sequence and value is not string %}
{{ key }}:
{% for item in value %}
  - {{ item }}
{% endfor %}
{% else %}
{{ key }}: {{ value }}
{% endif %}
{% endfor %}
{% endif %}
